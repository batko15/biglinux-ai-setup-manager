{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "description": "File system access for reading and writing files",
      "enabled": true
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub API integration for repos, issues, PRs",
      "enabled": false
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "description": "Persistent memory storage across sessions",
      "enabled": true
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "description": "Step-by-step reasoning for complex problems",
      "enabled": true
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@crystaldba/postgres-mcp"],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      },
      "description": "PostgreSQL database operations",
      "enabled": false
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"],
      "description": "Browser automation with Playwright",
      "enabled": false
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      },
      "description": "Web search capabilities",
      "enabled": false
    },
    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
      },
      "description": "Slack integration",
      "enabled": false
    },
    "google-maps": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-google-maps"],
      "env": {
        "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}"
      },
      "description": "Google Maps API",
      "enabled": false
    }
  },
  "agentCapabilities": {
    "codeGeneration": {
      "description": "Generate, debug, and explain code in multiple languages",
      "skills": ["llm", "code-gen", "code-review"]
    },
    "webDevelopment": {
      "description": "Create websites, APIs, and web applications",
      "skills": ["llm", "code-gen", "image-gen", "web-search"]
    },
    "research": {
      "description": "Deep research and information gathering",
      "skills": ["llm", "web-search", "summarize", "translate"]
    },
    "design": {
      "description": "UI/UX design and visual content creation",
      "skills": ["llm", "image-gen", "vlm", "design"]
    },
    "dataAnalysis": {
      "description": "Analyze and visualize data",
      "skills": ["llm", "code-gen", "data-analysis"]
    },
    "automation": {
      "description": "Automate workflows and tasks",
      "skills": ["llm", "code-gen", "sequential-thinking"]
    }
  }
}
